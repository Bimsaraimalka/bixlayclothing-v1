# Supabase (required for admin products/orders, storefront, customer auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Or use: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# Create admin user in Supabase Auth (run: node scripts/create-admin-user.js)
# Get from Supabase Dashboard → Project Settings → API → service_role (keep secret, never expose in client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# New order notification to admin phone (optional)
# Telegram: create a bot via @BotFather, then message your bot and get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
# ADMIN_TELEGRAM_BOT_TOKEN=your-bot-token
# ADMIN_TELEGRAM_CHAT_ID=your-chat-id
# SMS via Twilio: sign up at twilio.com, get credentials and a phone number
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
# ADMIN_PHONE_NUMBER=+1234567890

# Optional: keep Supabase free tier from pausing (low traffic). Set in Vercel → Project → Settings → Environment Variables.
# Cron hits /api/cron once per day; Vercel sends Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=your-random-secret

# Admin session: protects /admin routes in production. Set ADMIN_SESSION_SECRET (e.g. openssl rand -hex 32).
# When set, middleware only allows /admin/* with a valid session cookie set by POST /api/admin/login.
# ADMIN_SESSION_SECRET=your-random-secret

# Payzy payment gateway (optional). Get credentials from https://payzy.lk
# PAYZY_SHOP_ID=your-shop-id
# PAYZY_SECRET_KEY=your-secret-key
# PAYZY_TEST_MODE=true
# Next.js app URL for Payzy return URL (e.g. https://yourdomain.com). Vercel sets VERCEL_URL automatically.
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
